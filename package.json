{\n  "name": "barrelcox-homes",\n  "version": "1.0.0",\n  "description": "Luxury AI Real Estate Platform - Barrelcox Homes. Luxury Living Starts Here.",\n  "private": true,\n  "workspaces": [\n    "frontend",\n    "backend",\n    "shared"\n  ],\n  "scripts": {\n    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\"",\n    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",\n    "test": "npm run test --workspaces",\n    "test:frontend": "npm run test --workspace=frontend",\n    "test:backend": "npm run test --workspace=backend",\n    "test:coverage": "npm run test:coverage --workspaces",\n    "lint": "npm run lint --workspaces",\n    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",\n    "seed": "npm run seed --workspace=backend",\n    "docker:up": "docker-compose up -d",\n    "docker:down": "docker-compose down",\n    "docker:logs": "docker-compose logs -f"\n  },\n  "devDependencies": {\n    "concurrently": "^8.2.0",\n    "prettier": "^3.0.0",\n    "typescript": "^5.2.2"\n  },\n  "engines": {\n    "node": ">=18.0.0",\n    "npm": ">=9.0.0"\n  },\n  "keywords": [\n    "real-estate",\n    "luxury-homes",\n    "property-listing",\n    "saas",\n    "ai-powered",\n    "next.js",\n    "react",\n    "typescript",\n    "node.js",\n    "express"\n  ],\n  "author": "Barrelcox Homes",\n  "license": "MIT",\n  "homepage": "https://barrelcoxhomes.com",\n  "repository": {\n    "type": "git",\n    "url": "https://github.com/Randycox202/barrelcox-homes.git"\n  }\n}\n